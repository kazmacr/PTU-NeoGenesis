<form class="{{cssClass}} flexcol" autocomplete="off">
    
    <header class="sheet-header flexrow">
        <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
        <div class="header-fields flexcol">
            <h1 class="charname">
                <input name="name" type="text" value="{{item.name}}" placeholder="Nombre de la Especie"/>
            </h1>
            <div class="grid grid-2col">
                <div class="form-group">
                    <label>Tipo 1</label>
                    <select name="system.type1">
                        {{selectOptions config.tipos selected=system.type1 blank="-- Ninguno --"}}
                    </select>
                </div>
                <div class="form-group">
                    <label>Tipo 2</label>
                    <select name="system.type2">
                        {{selectOptions config.tipos selected=system.type2 blank="-- Ninguno --"}}
                    </select>
                </div>
            </div>
        </div>
    </header>

    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-tab="datos">Datos y Evolución</a>
        <a class="item" data-tab="stats">Stats y Movilidad</a>
        <a class="item" data-tab="listas">Listas de Aprendizaje</a>
    </nav>

    <section class="sheet-body">

        <div class="tab" data-group="primary" data-tab="datos">
            <div class="grid grid-2col">
                <fieldset>
                    <legend>Información General</legend>
                    <div class="form-group"><label>Tamaño</label><input type="text" name="system.size" value="{{system.size}}"/></div>
                    <div class="form-group"><label>Índice Peso</label><input type="number" name="system.weightClass" value="{{system.weightClass}}"/></div>
                    <div class="form-group"><label>Dieta</label><input type="text" name="system.diet" value="{{system.diet}}"/></div>
                    <div class="form-group"><label>Habitats</label><input type="text" name="system.habitats" value="{{system.habitats}}"/></div>
                    <div class="grid grid-3col" style="gap: 5px;">
                        <div class="form-group"><label>Grupo Huevo 1</label><input type="text" name="system.eggGroup1" value="{{system.eggGroup1}}"/></div>
                        <div class="form-group"><label>Grupo Huevo 2</label><input type="text" name="system.eggGroup2" value="{{system.eggGroup2}}"/></div>
                        <div class="form-group"><label>Días Eclosión</label><input type="number" name="system.hatchDays" value="{{system.hatchDays}}"/></div>
                    </div>
                    
                    <hr>
                    <label>Ratios de Género (%)</label>
                    <div class="grid grid-3col" style="gap: 5px; align-items: end;">
                        <div class="form-group flexcol">
                            <label><i class="fas fa-mars" style="color: #4b89dc;"></i> Macho</label>
                            <input type="number" name="system.gender.male" value="{{system.gender.male}}" step="0.1"/>
                        </div>
                        <div class="form-group flexcol">
                            <label><i class="fas fa-venus" style="color: #d75a8a;"></i> Hembra</label>
                            <input type="number" name="system.gender.female" value="{{system.gender.female}}" step="0.1"/>
                        </div>
                        <div class="form-group flexrow" style="justify-content: center; padding-bottom: 5px;">
                            <label title="Sin Género">Ninguno</label>
                            <input type="checkbox" name="system.gender.genderless" {{checked system.gender.genderless}}/>
                        </div>
                    </div>

                    <hr>
                    <div class="grid grid-2col" style="gap: 5px;">
                        <div class="form-group"><label>Acrobacias</label><input type="text" name="system.skills.acrobatics" value="{{system.skills.acrobatics}}" placeholder="2d6-3"/></div>
                        <div class="form-group"><label>Atletismo</label><input type="text" name="system.skills.athletics" value="{{system.skills.athletics}}" placeholder="2d6-3"/></div>
                        <div class="form-group"><label>Combate</label><input type="text" name="system.skills.combat" value="{{system.skills.combat}}" placeholder="2d6-3"/></div>
                        <div class="form-group"><label>Concentración</label><input type="text" name="system.skills.focus" value="{{system.skills.focus}}" placeholder="2d6-3"/></div>
                        <div class="form-group"><label>Percepción</label><input type="text" name="system.skills.perception" value="{{system.skills.perception}}" placeholder="2d6-3"/></div>
                        <div class="form-group"><label>Sigilo</label><input type="text" name="system.skills.stealth" value="{{system.skills.stealth}}" placeholder="2d6-3"/></div>                        
                    </div>
                </fieldset>
                
                <fieldset>
                    <legend>Lógica de Evolución</legend>
                    <div class="grid grid-2col" style="gap: 10px;">
                        <div class="form-group">
                            <label title="1=Base, 2=Fase 1, 3=Fase 2">Etapa</label>
                            <input type="number" name="system.evolution.stage" value="{{system.evolution.stage}}"/>
                        </div>
                        <div class="form-group">
                            <label title="Nivel mínimo para evolucionar (usar si el Director desactiva objetos)">Nivel Mín.</label>
                            <input type="number" name="system.evolution.evoLevel" value="{{system.evolution.evoLevel}}"/>
                        </div>
                    </div>
                    <div class="form-group flexcol">
                        <label>Siguiente(s) Etapa(s) (Separar por comas)</label>
                        <textarea name="system.evolution.nextStage" style="min-height: 45px; resize: none;" placeholder="Ej: Vaporeon, Jolteon, Flareon">{{system.evolution.nextStage}}</textarea>
                    </div>
                    <div class="form-group flexcol">
                        <label>Condiciones (Objetos, Horas, etc.)</label>
                        <textarea name="system.evolution.criteria" style="min-height: 45px; resize: none;" placeholder="Ej: Piedra Agua, Piedra Trueno, Piedra Fuego">{{system.evolution.criteria}}</textarea>
                    </div>
                </fieldset>
            </div>
        </div>

        <div class="tab" data-group="primary" data-tab="stats">
            <div class="grid grid-2col">
                <fieldset>
                    <legend>Estadísticas Base de Especie</legend>
                    {{#each system.stats as |stat key|}}
                    <div class="form-group">
                        <label style="text-transform: uppercase;">{{key}}</label>
                        <input type="number" name="system.stats.{{key}}.base" value="{{stat.base}}" data-dtype="Number"/>
                    </div>
                    {{/each}}
                </fieldset>
                <fieldset>
                    <legend>Capacidades de Desplazamiento</legend>
                    {{#each system.capabilities as |cap key|}}
                    <div class="form-group">
                        <label style="text-transform: capitalize;">{{localize (concat "PTUNG.Capabilities." key)}}</label>
                        <input type="number" name="system.capabilities.{{key}}" value="{{cap}}" data-dtype="Number"/>
                    </div>
                    {{/each}}
                </fieldset>
            </div>
        </div>

        <div class="tab" data-group="primary" data-tab="listas">
            <fieldset>
                <legend>Habilidades de Especie</legend>
                <div class="form-group"><label>Básicas</label><input type="text" name="system.lists.abilitiesBasic" value="{{system.lists.abilitiesBasic}}" placeholder="Separadas por comas"/></div>
                <div class="form-group"><label>Avanzadas</label><input type="text" name="system.lists.abilitiesAdvanced" value="{{system.lists.abilitiesAdvanced}}" placeholder="Separadas por comas"/></div>
                <div class="form-group"><label>Suprema</label><input type="text" name="system.lists.abilitiesHigh" value="{{system.lists.abilitiesHigh}}" placeholder="Separadas por comas"/></div>
            </fieldset>
            <fieldset>
                <legend>Movimientos y Capacidades Especiales</legend>
                <div class="form-group flexcol">
                    <label>Movimientos por Nivel (Ej: 1 Placaje, 5 Gruñido)</label>
                    <textarea name="system.lists.movesLevelUp" style="min-height: 80px;">{{system.lists.movesLevelUp}}</textarea>
                </div>
                <div class="form-group flexcol">
                    <label>Movimientos Tutor / Huevo</label>
                    <textarea name="system.lists.movesTutor" style="min-height: 60px;">{{system.lists.movesTutor}}</textarea>
                </div>
                <div class="form-group flexcol">
                    <label>Capacidades Especiales (Pokédex)</label>
                    <textarea name="system.lists.specialCapabilities" style="min-height: 60px;">{{system.lists.specialCapabilities}}</textarea>
                </div>
            </fieldset>
        </div>

    </section>
</form>