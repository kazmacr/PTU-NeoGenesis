<form class="{{cssClass}} flexcol" autocomplete="off">
    {{!-- Encabezado: PS (estilo Pokémon) y PAs --}}
    <header class="sheet-header flexrow">
        <div class="profile-hex-outer">
            <div class="profile-hex-inner">
                <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
            </div>
        </div>
        <div class="header-divider"></div>
        <div class="header-fields flexrow">
            <div class="header-main-info flexcol">
                <h1 class="charname">
                    <input type="text" name="name" value="{{actor.name}}" placeholder="Nombre del Entrenador" />
                </h1>
                <div class="resource-grid flexrow">
                    {{!-- Nivel --}}
                    <div class="resource flex-group-center lv-resource">
                        <label class="resource-label">Nivel</label>
                        <input type="number" name="system.level" value="{{system.level}}" data-dtype="Number" />
                    </div>

                    {{!-- Puntos de Salud (PS) --}}
                    <div class="resource hp-resource flexcol">
                        <label class="resource-label">{{localize "PTUNG.Stats.hp.name"}}</label>
                        <div class="resource-content hp-vertical-list">
                            <div class="form-group actual-hp">
                                <label>{{localize "PTUNG.Stats.hp.actual"}}</label>
                                <input type="number" name="system.health.value" value="{{system.health.value}}"
                                    data-dtype="Number" />
                            </div>
                            <div class="form-group max-hp">
                                <label>{{localize "PTUNG.Stats.hp.max"}}</label>
                                <input type="number" name="system.health.max" value="{{system.health.max}}" readonly />
                            </div>
                        </div>
                    </div>

                    {{!-- Puntos de Acción (PAs) --}}
                    <div class="resource flex-group-center" style="flex: 1;">
                        <label class="resource-label">PAs Actuales</label>
                        <div class="flexrow" style="align-items: center; gap: 5px;">
                            <input type="number" name="system.actionPoints.value" value="{{system.actionPoints.value}}"
                                style="width: 35px; height: 22px;" />
                            <span>/</span>
                            <input type="number" name="system.actionPoints.total" value="{{system.actionPoints.total}}"
                                style="width: 35px; height: 22px;" />
                        </div>
                        <div class="text-tiny italic">Vinculados: {{system.actionPoints.bonded}}</div>
                    </div>
                </div>
            </div>
            <div class="header-logo-block flex-group-center">
                <img src="systems/ptu-neogenesis/assets/images/logo_PTU_NeoGenesis.png" class="header-logo"
                    title="PTU Neo Genesis" />
            </div>
        </div>
    </header>

    {{!-- Navegación --}}
    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-tab="general">General</a>
        <a class="item" data-tab="talentos">Talentos y Rasgos</a>
        <a class="item" data-tab="combate">Combate</a>
        <a class="item" data-tab="inventario">Inventario</a>
        <a class="item" data-tab="cronica">Crónica</a>
        <a class="item" data-tab="niveles">Subida de Nivel</a>
        <a class="item" data-tab="importar">Importar</a>
    </nav>

    <section class="sheet-body">
        {{!-- Pestaña General --}}
        <div class="tab general" data-group="primary" data-tab="general">
            {{!-- Proporciones: 0.6 para datos, 1.1 para equipo y 1.3 para atributos --}}
            <div class="grid"
                style="display: grid; grid-template-columns: 0.6fr 1.1fr 1.3fr; gap: 10px; align-items: start;">

                {{!-- COLUMNA 1: Datos Físicos, Stats y Capacidades --}}
                <div class="flexcol">
                    <fieldset style="min-width: 0; padding: 5px;">
                        <legend>Datos Físicos</legend>
                        <div class="form-group" style="gap: 5px; margin: 2px 0;">
                            <label style="font-size: 11px; flex: 0 0 35px;">Género</label>
                            <select name="system.trainer.gender">
                                {{selectOptions @root.config.generoEntrenador selected=system.trainer.gender}}
                            </select>
                        </div>
                        <div class="form-group" style="gap: 5px; margin: 2px 0;">
                            <label style="font-size: 11px; flex: 0 0 35px;">Edad</label>
                            <input type="number" name="system.trainer.age" value="{{system.trainer.age}}"
                                style="height: 18px; font-size: 11px;" />
                        </div>
                        <div class="form-group" style="gap: 5px; margin: 2px 0;">
                            <label style="font-size: 11px; flex: 0 0 35px;">Altura</label>
                            <input type="text" name="system.trainer.height" value="{{system.trainer.height}}"
                                style="height: 18px; font-size: 11px;" />
                        </div>
                        <div class="form-group" style="gap: 5px; margin: 2px 0;">
                            <label style="font-size: 11px; flex: 0 0 35px;">Peso</label>
                            <input type="text" name="system.trainer.weight" value="{{system.trainer.weight}}"
                                style="height: 18px; font-size: 11px;" />
                        </div>
                    </fieldset>

                    {{!-- Stats del Entrenador --}}
                    <fieldset style="min-width: 0; padding: 5px; margin-top: 10px;">
                        <legend>Stats Base</legend>
                        <div class="grid grid-2col text-tiny align-center" style="gap: 5px;">
                            {{#each system.stats as |stat key|}}
                            <div class="stat-box flexcol"
                                style="background: rgba(0,0,0,0.05); border-radius: 3px; padding: 2px;">
                                <strong>{{localize (concat "PTUNG.Stats." key ".abbr")}}</strong>
                                <div class="flexrow" style="gap: 2px;">
                                    <input type="number" name="system.stats.{{key}}.base" value="{{stat.base}}"
                                        title="Base" style="height: 16px; font-size: 10px;" />
                                    <input type="number" name="system.stats.{{key}}.added" value="{{stat.added}}"
                                        title="Añadido" style="height: 16px; font-size: 10px;" />
                                </div>
                                <div class="stat-total"
                                    style="font-weight: bold; border-top: 1px solid #ccc; margin-top: 2px;">
                                    {{stat.total}}</div>
                            </div>
                            {{/each}}
                        </div>
                    </fieldset>

                    {{!-- Capacidades de Desplazamiento --}}
                    <fieldset style="min-width: 0; padding: 5px; margin-top: 10px;">
                        <legend>Capacidades</legend>
                        <div class="grid grid-2col text-tiny" style="gap: 2px;">
                            <div class="flexrow"><strong>Suelo: </strong> <span>{{system.capabilities.suelo}}</span></div>
                            <div class="flexrow"><strong>Nado: </strong> <span>{{system.capabilities.nado}}</span></div>
                            <div class="flexrow"><strong>Salto: </strong> <span>{{system.capabilities.salto}}</span></div>
                            <div class="flexrow"><strong>Alcance: </strong> <span>{{system.capabilities.alcance}}</span></div>
                            <div class="flexrow"><strong>Vigor:</strong> <span>{{system.capabilities.vigor}}</span></div>

                            {{!-- Cielo y Cavar automáticos (resaltados si son mayores a 0) --}}
                            <div class="flexrow">
                                <strong>Cielo: </strong> 
                                <span class="{{#if (gt system.capabilities.cielo 0)}}bold color-blue{{/if}}">
                                    {{system.capabilities.cielo}}
                                </span>
                            </div>
                            <div class="flexrow">
                                <strong>Cavar: </strong> 
                                <span class="{{#if (gt system.capabilities.cavar 0)}}bold color-blue{{/if}}">
                                    {{system.capabilities.cavar}}
                                </span>
                            </div>
                        </div>
                    </fieldset>
                    
                </div>

                {{!-- COLUMNA 2: Equipo Actual --}}
                <div class="flexcol">
                    <fieldset>
                        <legend>Equipo Pokémon</legend>
                        <div class="team-grid grid grid-2col" style="gap: 8px;">
                            {{#each pokemonTeam as |pkmn|}}
                            <div class="pokemon-slot" data-pkmn-id="{{pkmn.id}}" title="Abrir ficha de {{pkmn.name}}">
                                <img src="{{pkmn.img}}" width="45" height="45" style="border:none;" />
                                <div class="pkmn-name text-tiny">{{pkmn.name}}</div>
                            </div>
                            {{else}}
                            <p class="text-tiny italic align-center col-span-2" style="margin-top:20px;">Sin Pokémon
                                asignados</p>
                            {{/each}}
                        </div>
                    </fieldset>
                </div>

                {{!-- COLUMNA 3: Tabla de Atributos --}}
                <div class="flexcol">
                    <table class="ptu-table skills-table text-tiny">
                        <thead>
                            <tr style="background: #30A7D7; font-size: 11px; color: white;">
                                <th>Atributo</th>
                                <th title="Modificador">Mod.</th>
                                <th>Rango</th>
                                <th>Tirada</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each system.skills as |skill key|}}
                            <tr class="skill-row {{key}}">
                                <td class="align-left" style="font-size: 11px; padding: 2px;">
                                    <strong>{{localize (concat "PTUNG.Skills." key)}}</strong>
                                </td>
                                <td><input type="number" name="system.skills.{{key}}.mod" value="{{skill.mod}}"
                                        style="width: 22px; height: 18px; padding: 0;" /></td>
                                <td>
                                    <select name="system.skills.{{key}}.rank"
                                        style="font-size: 11px; height: 18px; padding: 0;">
                                        {{selectOptions @root.config.ranks selected=skill.rank}}
                                    </select>
                                </td>
                                <td class="rollable" data-roll="{{skill.rollFormula}}" data-label="{{key}}"
                                    style="cursor: pointer; background: rgba(0,0,0,0.05); font-weight: bold; text-align: center;">
                                    {{skill.rollFormula}}
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        {{!-- Pestaña Talentos y Rasgos --}}
        <div class="tab talentos" data-group="primary" data-tab="talentos">
            <fieldset>
                <legend>Talentos ({{system.talentLimits.current}} / {{system.talentLimits.base}} + {{system.talentLimits.extra}})</legend>
                <div class="grid grid-2col">
                    <div class="flexcol">
                        <div class="section-header flexrow">
                            <h3>Talentos de Clase</h3>
                            <a class="item-control item-create" data-type="feature"><i class="fas fa-plus"></i></a>
                        </div>
                        {{!-- Aquí se renderizarán los Talentos --}}
                    </div>
                    <div class="flexcol">
                        <div class="section-header flexrow">
                            <h3>Rasgos</h3>
                            <a class="item-control item-create" data-type="trait"><i class="fas fa-plus"></i></a>
                        </div>
                        {{!-- Aquí se renderizarán los Rasgos --}}
                    </div>
                </div>
            </fieldset>
        </div>

        {{!-- Pestaña Combate --}}
        <div class="tab combate" data-group="primary" data-tab="combate">
            <div class="combat-top-area flexrow">
                <div class="combat-col-desplazamiento">
                    <fieldset>
                        <legend>{{localize "PTUNG.Capabilities.Title"}}</legend>
                        <div class="desplazamiento-grid">
                            <div class="desp-subcol">
                                <div class="form-group stacked">
                                    <label>{{localize "PTUNG.Capabilities.overland"}}</label>
                                    <div class="desplazamiento flexrow flex-group-center cap-input-wrapper">
                                        <input type="number" name="system.capabilities.overland.base"
                                            value="{{system.capabilities.overland.base}}" data-dtype="Number"
                                            readonly />
                                    </div>
                                </div>
                                <div class="form-group stacked">
                                    <label>{{localize "PTUNG.Capabilities.swim"}}</label>
                                    <div class="desplazamiento flexrow flex-group-center cap-input-wrapper">
                                        <input type="number" name="system.capabilities.swim.base"
                                            value="{{system.capabilities.swim.base}}" data-dtype="Number" readonly />
                                    </div>
                                </div>
                                <div class="form-group stacked">
                                    <label>{{localize "PTUNG.Capabilities.jump"}}</label>
                                    <div class="desplazamiento flexrow flex-group-center cap-input-wrapper">
                                        <input type="number" name="system.capabilities.jump.base"
                                            value="{{system.capabilities.jump.base}}" data-dtype="Number" />
                                    </div>
                                </div>
                            </div>
                            <div class="desp-subcol">
                                <div class="form-group stacked">
                                    <label>{{localize "PTUNG.Capabilities.sky"}}</label>
                                    <div class="desplazamiento flexrow flex-group-center cap-input-wrapper">
                                        <input type="number" name="system.capabilities.sky.base"
                                            value="{{system.capabilities.sky.base}}" data-dtype="Number" readonly />
                                    </div>
                                </div>
                                <div class="form-group stacked">
                                    <label>{{localize "PTUNG.Capabilities.burrow"}}</label>
                                    <div class="desplazamiento flexrow flex-group-center cap-input-wrapper">
                                        <input type="number" name="system.capabilities.burrow.base"
                                            value="{{system.capabilities.burrow.base}}" data-dtype="Number" readonly />
                                    </div>
                                </div>
                                <div class="form-group stacked">
                                    <label>{{localize "PTUNG.Capabilities.power"}}</label>
                                    <div class="desplazamiento flexrow flex-group-center cap-input-wrapper">
                                        <input type="number" name="system.capabilities.power.base"
                                            value="{{system.capabilities.power.base}}" data-dtype="Number" readonly />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </fieldset>
                </div>
                <div class="combat-col-center flexcol">
                    <div class="combat-col-stats">
                        <table class="ptu-table">
                            <thead>
                                <tr>
                                    <th>{{localize "PTUNG.Stats.Label"}}</th>
                                    <th>Base</th>
                                    <th>{{localize "PTUNG.Stats.Added"}}</th>
                                    <th>Nat.</th>
                                    <th>BSP</th>
                                    <th title="Modificador de Combate (-6 a +6)">MC</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each system.stats as |stat key|}}
                                <tr>
                                    <td class="stat-name"><strong>{{localize (concat "PTUNG.Stats." key
                                            ".abbr")}}</strong>
                                    </td>
                                    <td><input type="number" name="system.stats.{{key}}.base" value="{{stat.base}}"
                                            data-dtype="Number" readonly /></td>
                                    <td><input type="number" name="system.stats.{{key}}.added" value="{{stat.added}}"
                                            data-dtype="Number" /></td>
                                    <td><input type="number" name="system.stats.{{key}}.natureModifier"
                                            value="{{stat.natureModifier}}" data-dtype="Number" /></td>
                                    <td class="bsp-cell">
                                        {{#if (eq ../system.bsp.primary key)}}<span
                                            title="Primario">+{{../system.bsp.mod1}}</span>
                                        {{else if (eq ../system.bsp.secondary key)}}<span
                                            title="Secundario">+{{../system.bsp.mod2}}</span>
                                        {{else if (eq ../system.bsp.tertiary key)}}<span
                                            title="Terciario">+{{../system.bsp.mod3}}</span>
                                        {{else}}0{{/if}}
                                    </td>
                                    <td>
                                        <select name="system.stats.{{key}}.combatStages" class="mc-input"
                                            data-dtype="Number">
                                            {{selectOptions @root.config.combatStages selected=stat.combatStages}}
                                        </select>
                                    </td>
                                    <td class="stat-total"><strong>{{stat.total}}</strong></td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                    <fieldset class="equipment-buffs-section">
                        <legend>Equipamiento</legend>
                        <div class="grid grid-3col">
                            <div class="form-group item-slot">
                                <label>Objeto Equipado</label>
                                <input type="text" name="system.equipment.held" value="{{system.equipment.held}}"
                                    placeholder="Ej: Tabla Elemental" />
                            </div>
                            <div class="form-group item-slot">
                                <label>Objeto Adicional</label>
                                <input type="text" name="system.equipment.extra" value="{{system.equipment.extra}}"
                                    placeholder="Ej: Banda aguante" />
                            </div>
                            <div class="form-group item-slot">
                                <label>Bufo de Comida</label>
                                <input type="text" name="system.equipment.food" value="{{system.equipment.food}}"
                                    placeholder="Ej: Restos" />
                            </div>
                        </div>
                    </fieldset>
                </div>
                <div class="combat-col-defensas flexcol">
                    <fieldset class="evasiones-box">
                        <legend title="Evasiones y Reducción de Daño">Evasiones y DR</legend>
                        <div class="form-group evasiones-header">
                            <label>Evasión</label>
                            <div class="flexrow">
                                <span class="eva-head-mod">Mod.</span>
                                <span class="eva-head-final">Final</span>
                            </div>
                        </div>
                        {{#each system.evasion as |evas key|}}
                        <div class="form-group evasion-row">
                            <label>{{localize (concat "PTUNG.Evasion." key)}}</label>
                            <div class="flexrow">
                                <input type="number" name="system.evasion.{{key}}.mod" value="{{evas.mod}}"
                                    placeholder="Mod" />
                                <span class="evasion-total">{{evas.value}}</span>
                            </div>
                        </div>
                        {{/each}}
                        <div class="form-group dr-row">
                            <label>Reducción Daño (DR)</label>
                            <input type="number" name="system.health.dr" value="{{system.health.dr}}"
                                data-dtype="Number" placeholder="0" />
                        </div>
                        <div class="form-group init-row">
                            <span class="init-total"></span>
                            <button type="button" class="roll-initiative" title="Lanzar Iniciativa"><i
                                    class="fas fa-dice-d20"></i>
                                Lanzar Iniciativa [{{system.stats.spd.total}}] </button>
                        </div>
                    </fieldset>
                    <fieldset>
                        <legend>Umbrales de Daño</legend>
                        <div class="health-thresholds grid grid-2col">
                            <div class="threshold"><span>Heridas:</span> <strong>{{system.health.injuries}}</strong>
                            </div>
                            <div class="threshold"><span>Tick:</span> <strong>{{system.health.tick}}</strong></div>
                            <div class="threshold"><span>1/2 HP:</span> <strong>{{system.health.half}}</strong></div>
                            <div class="threshold"><span>1/3 HP:</span> <strong>{{system.health.third}}</strong></div>
                            <div class="threshold"><span>1/4 HP:</span> <strong>{{system.health.quarter}}</strong></div>
                            <div class="threshold"><span>1/8 HP:</span> <strong>{{system.health.eighth}}</strong></div>
                            <div class="threshold"><span>1/16 HP:</span> <strong>{{system.health.sixteenth}}</strong>
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
            <div class="combat-bottom-area">
                <div class="moves-section">
                    <div class="section-header flexrow">
                        <h3>{{localize "TYPES.Item.move"}} (<span class="move-count">{{moves.length}}</span> / 11)</h3>
                        {{#if (lt moves.length 11)}}
                        <a class="item-control item-create" title="Agregar Movimiento" data-type="move"><i
                                class="fas fa-plus"></i></a>
                        {{/if}}
                    </div>
                    <ol class="items-list">
                        <li class="item flexrow list-header">
                            <div class="item-name">Nombre</div>
                            <div class="item-detail">Tipo</div>
                            <div class="item-detail">Categoría</div>
                            <div class="item-detail">Frecuencia</div>
                            <div class="item-detail">DB</div>
                            <div class="item-detail">Efecto</div>
                            <div class="item-controls"></div>
                        </li>
                        {{#each moves as |item id|}}
                        <li class="item flexrow" data-item-id="{{item._id}}">
                            <div class="item-name flexrow">
                                <img src="{{item.img}}" title="{{item.name}}" width="24" height="24" />
                                <h4>{{item.name}}</h4>
                            </div>
                            <div class="item-detail type-badge" data-type="{{item.system.type}}">{{item.system.type}}
                            </div>
                            <div class="item-detail">{{item.system.category}}</div>
                            <div class="item-detail">{{item.system.frequency}}</div>
                            <div class="item-detail"><strong>{{item.system.damageBase}}</strong></div>
                            <div class="item-detail">{{item.system.effects}}</div>
                            <div class="item-controls">
                                <a class="item-control item-edit" title="Editar"><i class="fas fa-edit"></i></a>
                                {{#if (ne item.name "Forcejeo")}}
                                <a class="item-control item-delete" title="Eliminar"><i class="fas fa-trash"></i></a>
                                {{/if}}
                            </div>
                        </li>
                        {{/each}}
                    </ol>
                </div>
            </div>
        </div>

        {{!-- Pestaña Inventario --}}
        <div class="tab inventario" data-group="primary" data-tab="inventario">
            <div class="section-header flexrow">
                <h3>Inventario y Mochila</h3>
                <a class="item-control item-create" data-type="gear"><i class="fas fa-plus"></i></a>
            </div>
            {{!-- Aquí puedes clasificar por Consumibles, Equipo, etc. --}}
        </div>

        {{!-- Pestaña Crónica (Narrativa Movida Aquí) --}}
        <div class="tab cronica" data-group="primary" data-tab="cronica">
            <div class="grid grid-2col">
                <div class="flexcol">
                    <fieldset>
                        <legend>Personalidad</legend>
                        <textarea name="system.personality" rows="10"
                            style="resize: vertical; border:none;">{{system.personality}}</textarea>
                    </fieldset>
                    <fieldset style="margin-top: 10px;">
                        <legend>Sueños, Objetivos y Obsesiones</legend>
                        <textarea name="system.goals" rows="10"
                            style="resize: vertical; border:none;">{{system.goals}}</textarea>
                    </fieldset>
                </div>
                <div class="flexcol">
                    <fieldset>
                        <legend>Descripción Física e Imagen</legend>
                        {{editor enrichedPhysicalDescription target="system.physicalDescription" engine="prosemirror"
                        button=true editable=editable}}
                    </fieldset>
                    <fieldset style="margin-top: 10px;">
                        <legend>Historia / Biografía</legend>
                        {{editor enrichedBiography target="system.biography" engine="prosemirror" button=true
                        editable=editable}}
                    </fieldset>
                </div>
                <div class="flexcol">
                    <fieldset style="margin-top: 10px;">
                        <legend>Notas de la partida</legend>
                        {{editor enrichedPlayerNotes target="system.playerNotes" engine="prosemirror" button=true
                        editable=editable}}
                    </fieldset>
                </div>
            </div>
        </div>

        {{!-- Pestaña Subida de Nivel --}}
        <div class="tab niveles" data-group="primary" data-tab="niveles">
            <div class="grid grid-2col">
                <fieldset>
                    <legend>Progreso de Nivel</legend>
                    <div class="form-group">
                        <label>Experiencia Actual</label>
                        <input type="number" name="system.experience" value="{{system.experience}}" />
                    </div>
                </fieldset>
                <fieldset>
                    <legend>Gestión de Puntos</legend>
                    <p class="text-small italic">Puntos de Atributo y Talentos ganados por nivel.</p>
                </fieldset>
            </div>
        </div>

        {{!-- Pestaña Importar --}}
        <div class="tab importar" data-group="primary" data-tab="importar">
            <fieldset>
                <legend>Importar desde Google Sheets (Entrenador)</legend>
                <div class="form-group" style="display: flex; gap: 10px; border: none;">
                    {{!-- Input largo para la URL --}}
                    <input type="text" id="import-trainer-url" placeholder="https://docs.google.com/spreadsheets/d/..."
                        style="flex: 4; height: 28px;" />

                    {{!-- Botón angosto --}}
                    <button type="button" class="btn-import"
                        style="flex: 1; max-width: 120px; white-space: nowrap; height: 28px; line-height: normal;">
                        <i class="fas fa-file-import"></i> Procesar
                    </button>
                </div>
                <p class="notes" style="font-size: 10px; margin-top: 5px; color: #666;">
                    Asegúrate de que la hoja de cálculo sea pública o tenga los permisos de lectura activados.
                </p>
            </fieldset>
        </div>
    </section>
</form>